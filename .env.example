# ═══════════════════════════════════════════════
# mlops-platform environment configuration
# Copy this to .env and fill in your values
# ═══════════════════════════════════════════════

# MySQL Database (platform tables + result tables)
MYSQL_USER=mlops
MYSQL_PASS=mlops123
MYSQL_HOST=127.0.0.1
MYSQL_PORT=3306

# MLflow (shared model registry)
MLFLOW_TRACKING_URI=http://127.0.0.1:5000
MLFLOW_S3_ENDPOINT_URL=http://127.0.0.1:9000

# MinIO credentials (used as AWS keys by MLflow/boto3)
AWS_ACCESS_KEY_ID=minioadmin
AWS_SECRET_ACCESS_KEY=minioadmin

# Airflow (for docker-compose)
_AIRFLOW_WWW_USER_USERNAME=admin
_AIRFLOW_WWW_USER_PASSWORD=admin

# Slack (for alerting — optional, Phase 2+)
# SLACK_WEBHOOK_URL=https://hooks.slack.com/services/...
